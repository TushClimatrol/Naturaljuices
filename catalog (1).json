[{"name": "Naturaljuices LoveNoni Organic Certified 100% Pure Noni Juice", "cat": "noni", "price": 16.99, "was": 19.99, "img": "https://www.naturaljuices.co.uk/images/products/1741178818910.png", "rev": 4, "out": false, "benefit": "Helps pain and inflammation| Restore Energy Levels| Combats fatigue| Optimises Endurance| Supports Joint and Muscle Health", "gallery": ["https://www.naturaljuices.co.uk/images/products/1741178818910.png", "https://www.naturaljuices.co.uk/images/products/174117881881.png", "https://www.naturaljuices.co.uk/images/products/1741178818952.png", "https://www.naturaljuices.co.uk/images/products/1741178818833.png", "https://www.naturaljuices.co.uk/images/products/1741178818954.png", "https://www.naturaljuices.co.uk/images/products/1684483092228.webp"], "packs": [["Single Product", 16.99], ["Pack of 2 Bottles", 16.15], ["Pack of 4 Bottles", 15.0], ["Pack of 6 Bottles", 15.29]], "stock": 920, "id": 1, "goals": ["energy", "immunity"], "size": "500ml Glass Bottle", "desc": "<p>Derived from the fruit of the <em>Morinda citrifolia</em> tree, which grows in the tropical regions of the Pacific Islands, Southeast Asia and India, Noni juice has been used for centuries in traditional medicine. Today, Organic Certified Noni Juice is celebrated for its ability to support overall well-being, support the immune system and improve energy levels.</p><p>Noni juice is packed with an array of essential nutrients, including vitamins, minerals, antioxidants and phytochemicals. It is particularly rich in vitamin C, which supports the immune system, and potassium, which is essential for heart health. Noni also contains unique compounds like xeronine, believed to support cellular function and repair, and scopoletin, known for its anti-inflammatory properties.</p><p>Our 100% Organic Certified Noni Juice is made from organically grown Noni fruit \u2014 free from pesticides and synthetic fertilisers \u2014 carefully harvested and gently extracted to preserve its natural nutrients and potency, then bottled in premium glass.</p>", "ing": "<p>100% Pure Organic Certified Noni Juice (<em>Morinda citrifolia</em>) \u2014 organically grown, free from pesticides, synthetic fertilisers and unwanted additives. Organic certification: GB-ORG-04.</p>"}, {"name": "NaturalJuices LoveNoni For Men Ultra Potent Formula", "cat": "noni", "price": 23.74, "was": 24.99, "img": "https://www.naturaljuices.co.uk/images/products/1684482768180.webp", "rev": 0, "out": true, "benefit": "Noni For Men Vitality Formula", "gallery": ["https://www.naturaljuices.co.uk/images/products/1684482768180.webp"], "packs": [], "stock": null, "id": 2, "goals": ["immunity"], "size": ""}, {"name": "NaturalJuices Organic Certified Love Noni Juice Blend with Raspberry", "cat": "noni", "price": 28.49, "was": 29.99, "img": "https://www.naturaljuices.co.uk/images/products/1757414305580.png", "rev": 0, "out": false, "benefit": "Noni Juice with Raspberry Flavour| Organic Certified| Premium Glass Bottle", "gallery": ["https://www.naturaljuices.co.uk/images/products/1757414305580.png", "https://www.naturaljuices.co.uk/images/products/1757414756871.png", "https://www.naturaljuices.co.uk/images/products/1757414756992.png", "https://www.naturaljuices.co.uk/images/products/1577340223front3", "https://www.naturaljuices.co.uk/images/products/1577340223front4", "https://www.naturaljuices.co.uk/images/products/1577340223G"], "packs": [["Single Product", 28.49], ["Pack of 2 Bottles", 26.99], ["Pack of 3 Bottles", 25.49], ["Pack of 4 Bottles", 23.99]], "stock": 449, "id": 3, "goals": ["immunity"], "size": "946ml Premium Glass Bottle", "desc": "<p>All the goodness of our Organic Certified Noni Juice, made even more enjoyable. Noni's traditional, distinctive taste isn't for everyone \u2014 so we developed this special variant blended with raspberry: the same powerful superfruit supplement with a smoother, fruitier flavour.</p><p>Noni juice is rich in vitamin C, potassium, antioxidants and unique phytoc